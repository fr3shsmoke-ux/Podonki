# Podonki Content Generation — Environment Variables

# ========== CLAUDE API ==========
# Получить ключ: https://console.anthropic.com/
# Скопировать и вставить сюда
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ========== TELEGRAM (для n8n) ==========
# Bot token: получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Channel IDs: можно получить через @getidsbot
TELEGRAM_B2C_CHANNEL_ID=-100123456789
TELEGRAM_TRAIN_LAB_CHANNEL_ID=-100987654321
TELEGRAM_PODONKI_OFF_CHANNEL_ID=-100555666777

# ========== DATABASE ==========
# Обычно не нужно менять, используется по умолчанию
DB_PATH=./data

# ========== n8n (если используешь) ==========
# Не обязательно
N8N_API_KEY=your_n8n_key_here
