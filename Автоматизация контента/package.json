{
  "name": "podonki-automation",
  "version": "1.0.0",
  "type": "module",
  "description": "Система автоматизации постинга и управления каналами Podonki",
  "main": "scripts/parse-telegram.js",
  "scripts": {
    "parse": "node scripts/parse-telegram.js",
    "generate": "node src/generators/post-generator.js",
    "analyze": "node scripts/analyze-datasets.js",
